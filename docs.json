{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "aspen",
  "name": "Nyuchi Docs",
  "description": "Documentation for Nyuchi — the platform, products, and the Nyuchi Design System.",
  "colors": {
    "primary": "#5D4037",
    "light": "#FFD740",
    "dark": "#3E2723"
  },
  "fonts": {
    "family": "Noto",
    "weight": 500,
    "format": "woff2",
    "heading": { "family": "Noto Serif" },
    "body": { "family": "Noto Sans" }
  },
  "background": { "decoration": "grid" },
  "appearance": { "default": "system" },
  "favicon": {
    "light": "/favicon.svg",
    "dark": "/favicon-dark.svg"
  },
  "icons": {
    "library": "lucide"
  },
  "styling": {
    "eyebrows": "breadcrumbs"
  },
  "contextual": {
    "options": ["copy", "view", "assistant", "mcp", "add-mcp"]
  },
  "navigation": {
    "pages": ["index"]
  },
  "logo": {
    "light": "/images/nyuchi-docs.svg",
    "dark": "/images/nyuchi-docs-dark.svg"
  },
  "navbar": {
    "links": [],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://dashboard.mintlify.com"
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/nyuchiafrica",
      "linkedin": "https://linkedin.com/company/nyuchi",
      "github": "https://github.com/nyuchi"
    }
  }
}
