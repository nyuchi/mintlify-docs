{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "aspen",
  "name": "Nyuchi Docs",
  "description": "Documentation for Nyuchi — the platform, products, and the Nyuchi Design System.",
  "colors": {
    "primary": "#5D4037",
    "light": "#FFD740",
    "dark": "#3E2723"
  },
  "fonts": {
    "family": "Noto",
    "weight": 500,
    "format": "woff2",
    "heading": { "family": "Noto Serif" },
    "body": { "family": "Noto Sans" }
  },
  "background": { "decoration": "grid" },
  "appearance": { "default": "system" },
  "favicon": {
    "light": "/favicon.svg",
    "dark": "/favicon-dark.svg"
  },
  "icons": {
    "library": "lucide"
  },
  "styling": {
    "eyebrows": "breadcrumbs"
  },
  "contextual": {
    "options": ["copy", "view", "assistant", "mcp", "add-mcp"]
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Home",
          "icon": "house",
          "href": "/"
        },
        {
          "anchor": "Changelog",
          "icon": "scroll-text",
          "href": "https://www.mintlify.com/docs/changelog"
        },
        {
          "anchor": "Help",
          "icon": "life-buoy",
          "href": "https://www.mintlify.com/docs/contact-support"
        }
      ]
    },
    "directory": "card",
    "products": [
      {
        "product": "Platform",
        "description": "Core platform setup, configuration, and administration.",
        "icon": "layers",
        "groups": [
          {
            "group": "Getting started",
            "icon": "rocket",
            "expanded": true,
            "pages": [
              "platform/quickstart",
              "platform/key-concepts"
            ]
          },
          {
            "group": "Configuration",
            "icon": "settings",
            "expanded": true,
            "pages": [
              "platform/configuration/settings",
              "platform/configuration/user-management"
            ]
          },
          {
            "group": "Administration",
            "icon": "shield-check",
            "expanded": true,
            "pages": [
              "platform/administration/roles-permissions",
              "platform/administration/audit-logs"
            ]
          }
        ]
      },
      {
        "product": "Analytics",
        "description": "Build dashboards, run reports, and analyze your data.",
        "icon": "chart-bar",
        "groups": [
          {
            "group": "Getting started",
            "icon": "rocket",
            "expanded": true,
            "pages": [
              "analytics/quickstart",
              "analytics/connect-data"
            ]
          },
          {
            "group": "Dashboards",
            "icon": "layout-dashboard",
            "expanded": true,
            "pages": [
              "analytics/dashboards/create-dashboard",
              "analytics/dashboards/charts-visualizations",
              "analytics/dashboards/sharing-exports"
            ]
          },
          {
            "group": "Reports",
            "icon": "file-chart-column",
            "expanded": true,
            "pages": [
              "analytics/reports/build-report",
              "analytics/reports/scheduled-reports"
            ]
          }
        ]
      },
      {
        "product": "Integrations",
        "description": "Connect your tools with pre-built connectors and webhooks.",
        "icon": "plug",
        "groups": [
          {
            "group": "Getting started",
            "icon": "rocket",
            "expanded": true,
            "pages": [
              "integrations/quickstart",
              "integrations/authentication"
            ]
          },
          {
            "group": "Connectors",
            "icon": "cable",
            "expanded": true,
            "pages": [
              "integrations/connectors/crm",
              "integrations/connectors/data-warehouse",
              "integrations/connectors/messaging"
            ]
          },
          {
            "group": "Webhooks & events",
            "icon": "webhook",
            "expanded": true,
            "pages": [
              "integrations/webhooks/configure",
              "integrations/webhooks/event-types",
              "integrations/webhooks/retry-policies"
            ]
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/images/nyuchi-docs.svg",
    "dark": "/images/nyuchi-docs-dark.svg"
  },
  "navbar": {
    "links": [],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://dashboard.mintlify.com"
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/nyuchiafrica",
      "linkedin": "https://linkedin.com/company/nyuchi",
      "github": "https://github.com/nyuchi"
    }
  }
}
